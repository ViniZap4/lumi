# lumi v2 — environment variables for docker compose.
#
# Copy to .env and edit before running `docker compose up -d`.
# Anything left blank falls back to the defaults defined in docker-compose.yml.

# ── Postgres ─────────────────────────────────────────────
# Credentials for the bundled Postgres service. The server uses these
# to compose LUMI_DATABASE_URL — you do NOT need to set the URL by hand.
# Override POSTGRES_PASSWORD before exposing the deployment.
POSTGRES_USER=lumi
POSTGRES_PASSWORD=lumi
POSTGRES_DB=lumi

# ── Server ───────────────────────────────────────────────
# Host port the API listens on. Server binds 0.0.0.0:8080 inside the
# container; this maps to the host. The web client image is built with
# LUMI_SERVER_URL embedded — rebuild `web` if you change this.
LUMI_PORT=8080

# Host path mounted at /vaults inside the server container. Each vault
# lives at <VAULTS_PATH>/<vault-slug>/ with notes + .lumi/ metadata.
VAULTS_PATH=./vaults

# TLS is required by default whenever the server binds a non-loopback
# address. The compose default is "false" because Postgres + server are
# expected to sit behind a reverse proxy or local-only. Flip to "true"
# in prod (with TLS terminated upstream).
LUMI_REQUIRE_TLS=false

# CSV of allowed origins for CORS. Browsers will only attach session
# cookies to requests whose Origin is on this list. Update if you serve
# the web client from a different host/port.
LUMI_ALLOWED_ORIGINS=http://localhost:3000

# Registration policy: "invite-only" (default) or "open".
# Invite-only — first signup requires an invite token; subsequent users
# can only join via invite link from an existing vault admin.
LUMI_REGISTRATION=invite-only

# Audit log retention in days. LGPD baseline. Lower bound 1, no upper.
LUMI_AUDIT_RETENTION_DAYS=90

# Apply pending SQL migrations at startup. Convenient for compose; flip
# to "false" in environments where you run `lumi-server migrate up`
# explicitly during a deploy step.
LUMI_AUTO_MIGRATE=true

# First-boot admin bootstrap. If BOTH are set and the users table is
# empty, the server creates a single admin account with these creds.
# Leave blank if you'd rather bootstrap manually via the invite flow.
# Recommended: set these for the first start, then unset and redeploy.
LUMI_ADMIN_USERNAME=
LUMI_ADMIN_PASSWORD=

# Public URL where invite links should resolve (e.g. https://lumi.example.com).
# Optional; falls back to relative paths when unset.
LUMI_PUBLIC_BASE_URL=

# Consent versions. If BOTH are set, the server records explicit
# ToS/privacy consent at signup. Leave blank to skip consent capture.
LUMI_TOS_VERSION=
LUMI_PRIVACY_VERSION=

# Logging. Format: "json" (default, machine-readable) or "console" (dev).
# Level: debug | info | warn | error.
LUMI_LOG_FORMAT=json
LUMI_LOG_LEVEL=info

# ── Web Client ───────────────────────────────────────────
# Host port mapped to the nginx-served web client (internal: 80).
WEB_PORT=3000

# URL the browser uses to reach the API. Baked into the JS bundle at
# image build time — changing it requires `docker compose build web`.
LUMI_SERVER_URL=http://localhost:8080
