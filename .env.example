# ── Server ────────────────────────────────────────────────
LUMI_PASSWORD=dev              # Auth token (required for all API/WS access)
LUMI_PORT=8080                 # Server port (internal: always 8080, this maps the host port)
NOTES_PATH=./notes             # Path to notes directory (mounted into container)

# ── Web Client ────────────────────────────────────────────
WEB_PORT=3000                  # Web UI host port
LUMI_SERVER_URL=http://localhost:8080  # Server URL as seen by the browser (baked at build time)

# ── Peer Sync (optional) ─────────────────────────────────
# LUMI_SERVER_ID=              # Unique server ID (auto-generated if empty)
# LUMI_PEERS=                  # Comma-separated peer URLs (e.g. http://peer1:8080,http://peer2:8080)
