# ── Server ────────────────────────────────────────────────
# Password used for all authentication: web login, REST API
# (X-Lumi-Token header), and WebSocket (?token= query param).
LUMI_PASSWORD=dev

# Host port mapped to the server container (internal is always 8080).
LUMI_PORT=8080

# Host path to the notes directory — mounted into the server container.
NOTES_PATH=./notes

# ── Web Client ────────────────────────────────────────────
# Host port mapped to the web client container (serves via nginx on 80).
WEB_PORT=3000

# URL the browser uses to reach the API server. Baked into the web
# client bundle at build time — changing it requires a rebuild
# (docker compose build web).
LUMI_SERVER_URL=http://localhost:8080

# ── Peer Sync (optional) ─────────────────────────────────
# Unique server ID for peer sync. Auto-generated if left empty.
# LUMI_SERVER_ID=

# Comma-separated URLs of peer lumi servers to federate with.
# Example: http://peer1:8080,http://peer2:8080
# LUMI_PEERS=
